# The bits we actually depend on (paper template, CERN-OHL-P license) are
# already copied into codemyriad-protogon/. Excluded to avoid an embedded repo.
/_upstream_badge_2024_hardware/

# --- Scratch render dirs ---
renders/*-test/
**/renders/*-test/

# --- OS cruft ---
.DS_Store
Thumbs.db
