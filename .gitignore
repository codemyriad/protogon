# --- Build / run logs (regenerated by the generator + render scripts) ---
*.log

# --- Python ---
__pycache__/
*.py[cod]

# --- KiCad local state, autosaves and backups ---
*.kicad_prl
*-backups/
_autosave-*
*.bak
*-bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.lck
fp-info-cache

# --- Upstream reference clone (kept locally for reference, not vendored) ---
