# --- Build / run logs (regenerated by the generator + render scripts) ---
*.log

# --- Python ---
__pycache__/
*.py[cod]

# --- KiCad local state, autosaves and backups ---
*.kicad_prl
*-backups/
_autosave-*
*.bak
*-bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.lck
*.rpt
fp-info-cache

# --- LibreOffice / editor lock files (e.g. BOM csv opened in Calc) ---
.~lock.*#

# --- Upstream reference clone (only needed by archive/tools/generate_protogon.py) ---
# A clone of github.com/emfcamp/badge-2024-hardware with its own .git. The bits we
# actually depend on (paper template, CERN-OHL-P license) are already in the repo.
# Excluded to avoid an embedded repo.
/_upstream_badge_2024_hardware/

# --- Scratch render dirs ---
renders/*-test/
**/renders/*-test/

# --- OS cruft ---
.DS_Store
Thumbs.db
.gstack/
